@model List<DropThisSite.Models.Order>

<div class="container my-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <h1 class="display-4 fw-bold text-warning">
            <i class="fas fa-box me-2"></i>Мои заказы
        </h1>
        <a asp-controller="Jewelries" asp-action="Index" class="btn btn-outline-warning">
            <i class="fas fa-shopping-bag me-2"></i>Продолжить покупки
        </a>
    </div>

    @if (Model.Any())
    {
        @foreach (var order in Model)
        {
            <div class="card shadow-sm mb-4">
                <div class="card-header bg-light">
                    <div class="row align-items-center">
                        <div class="col-md-6">
                            <strong>Заказ от @order.OrderDate.ToString("dd.MM.yyyy HH:mm")</strong>
                        </div>
                        <div class="col-md-3">
                            <span class="badge bg-@(order.StatusOrder?.NameStatusOrder switch
                             {
                                "Новый" => "warning",
                                "В обработке" => "info",
                                "Отправлен" => "success",
                                _ => "secondary"
                             })">
                                @order.StatusOrder?.NameStatusOrder
                            </span>
                        </div>
                        <div class="col-md-3 text-end">
                            <span class="h5 text-warning">@order.TotalPrice ₽</span>
                        </div>
                    </div>
                </div>
                <div class="card-body">
                    <div class="row align-items-center">
                        <div class="col-md-2 text-center">
                            <i class="fas fa-gem fa-3x text-warning mb-3"></i>
                            <div>@order.Quantity шт.</div>
                        </div>
                        <div class="col-md-5">
                            <h5>@order.Jewelry?.NameJewelry</h5>
                            <p class="text-muted mb-1">@order.Jewelry?.Material?.NameMaterial</p>
                            @if (order.Jewelry?.Stone != null)
                            {
                                <p class="text-muted mb-0">@order.Jewelry.Stone.ColorStone</p>
                            }
                        </div>
                        <div class="col-md-5">
                            <p><strong>Телефон:</strong> @order.User?.Phone</p>
                            <p><strong>Email:</strong> @order.User?.Email</p>
                        </div>
                    </div>
                </div>
            </div>
        }
    }
    else
    {
        <div class="text-center py-5">
            <i class="fas fa-inbox fa-5x text-muted mb-4"></i>
            <h3 class="text-muted">У вас пока нет заказов</h3>
            <p class="lead text-muted">Оформите первый заказ в каталоге!</p>
            <a asp-controller="Jewelries" asp-action="Index" class="btn btn-warning btn-lg">
                <i class="fas fa-gem me-2"></i>Перейти в каталог
            </a>
        </div>
    }
</div>
