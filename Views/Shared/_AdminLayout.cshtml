<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>Админ-панель — @ViewData["Title"]</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body class="bg-light">
    <div class="container-fluid">
        <div class="row min-vh-100">
            <nav class="col-md-3 col-lg-2 d-md-block bg-dark sidebar py-4">
                <div class="position-sticky">
                    <h4 class="text-warning text-center mb-4">
                        <i class="fas fa-crown me-2"></i>Админ-панель
                    </h4>
                    <ul class="nav flex-column px-2 gap-1">
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Admin" asp-action="Index"><i class="fas fa-gauge-high me-2"></i>Сводка</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Jewelries" asp-action="Index"><i class="fas fa-gem me-2"></i>Товары</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="JewelryTips" asp-action="Index"><i class="fas fa-list me-2"></i>Категории</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Suppliers" asp-action="Index"><i class="fas fa-tags me-2"></i>Бренды</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="AdminOrders" asp-action="Index"><i class="fas fa-box me-2"></i>Заказы</a></li>
                        <li class="nav-item"><a class="nav-link text-white" asp-controller="Users" asp-action="Index"><i class="fas fa-users me-2"></i>Пользователи</a></li>
                        <li class="nav-item mt-3"><a class="nav-link text-danger" asp-controller="Account" asp-action="Logout"><i class="fas fa-sign-out-alt me-2"></i>Выйти</a></li>
                    </ul>
                </div>
            </nav>

            <main class="col-md-9 ms-sm-auto col-lg-10 px-md-4 py-4">
                @RenderBody()
            </main>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
