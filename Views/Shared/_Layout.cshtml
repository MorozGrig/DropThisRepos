<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - DropThisSite</title>
    <script type="importmap"></script>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/DropThisSite.styles.css" asp-append-version="true" />
</head>
<body>
    <header>
        <nav class="navbar navbar-expand-lg navbar-dark bg-dark sticky-top shadow-lg">
            <div class="container">
                <a class="navbar-brand fw-bold fs-3" asp-controller="Home" asp-action="Index">
                    <i class="fas fa-gem me-2 text-warning"></i>Ювелирка
                </a>
                <div class="collapse navbar-collapse" id="navbarNav">
                    <ul class="navbar-nav me-auto">
                        <li class="nav-item">
                            <a class="nav-link" asp-controller="Jewelries" asp-action="Index">Каталог</a>
                        </li>
                    </ul>
                    <ul class="navbar-nav">
                        <li class="nav-item position-relative me-3">
                            <a class="nav-link position-relative p-2" asp-controller="Home" asp-action="Cart">
                                <i class="fas fa-shopping-cart fs-5"></i>
                                <span class="badge bg-danger position-absolute top-0 start-100 translate-middle rounded-pill"
                                      id="cartCount" style="font-size: 0.7em; min-width: 20px;">
                                    0
                                </span>
                            </a>
                        </li>
                        <!-- АВТОРИЗАЦИЯ -->
                        @if (User.Identity.IsAuthenticated)
                        {
                            <li class="nav-item dropdown">
                                <a class="nav-link dropdown-toggle d-flex align-items-center p-2" href="#"
                                       data-bs-toggle="dropdown">
                                    <i class="fas fa-user-circle fs-4 me-2"></i>@User.Identity.Name
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end">
                                    <li><a class="dropdown-item" asp-controller="Account" asp-action="Profile"><i class="fas fa-user me-2"></i>Профиль</a></li>
                                    <li>
                                        <a class="dropdown-item" asp-controller="Orders" asp-action="History">
                                            <i class="fas fa-box me-2"></i>Заказы
                                        </a>
                                    </li>
                                    @if (User.IsInRole("Админ"))
                                    {
                                        <li><hr class="dropdown-divider"></li>
                                        <li>
                                            <a class="dropdown-item" asp-controller="Admin" asp-action="Index">
                                                <i class="fas fa-crown me-2 text-warning"></i>Админка
                                            </a>
                                        </li>
                                    }
                                    <li><hr class="dropdown-divider"></li>
                                    <form asp-controller="Account" asp-action="Logout" method="post" class="px-2">
                                        <button type="submit" class="dropdown-item text-danger">
                                            <i class="fas fa-sign-out-alt me-2"></i>Выйти
                                        </button>
                                    </form>
                                </ul>
                            </li>
                        }
                        else
                        {
                            <li class="nav-item">
                                <a class="nav-link btn btn-outline-light px-3 py-2 me-2" asp-controller="Account" asp-action="Login">
                                    <i class="fas fa-sign-in-alt me-1"></i>Войти
                                </a>
                            </li>
                            <li class="nav-item">
                                <a class="nav-link btn btn-warning text-dark px-4 py-2 fw-bold" asp-controller="Account" asp-action="Register">
                                    Регистрация
                                </a>
                            </li>
                        }
                    </ul>
                </div>
            </div>
        </nav>
    </header>
    <div class="container">
        <main role="main" class="pb-3">
            @RenderBody()
        </main>
    </div>

    <footer class="bg-dark text-white py-4 mt-5">
        <div class="container text-center">
            <p>&copy; 2026 Ювелирный магазин. Все права защищены.</p>
        </div>
    </footer>
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
