@model DropThisSite.Models.Stone

@{
    ViewData["Title"] = "Удаление";
}

<h1>Удалить</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Камень</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NameStone)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NameStone)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.ColorStone)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.ColorStone)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.WeightStone)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.WeightStone)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="IdStone" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-action="Index">Назад к списку</a>
    </form>
</div>
