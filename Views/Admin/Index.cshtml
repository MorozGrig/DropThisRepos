@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Панель управления";
}

<div class="d-flex justify-content-between flex-wrap flex-md-nowrap align-items-center pt-3 pb-2 mb-3 border-bottom">
    <h1 class="h2 text-warning">💎 Панель управления</h1>
</div>

<div class="row">
    <div class="col-xl-3 col-md-6 mb-4">
        <div class="card border-left-warning shadow h-100 py-2">
            <div class="card-body">
                <div class="row no-gutters align-items-center">
                    <div class="col mr-2">
                        <div class="text-xs font-weight-bold text-warning text-uppercase mb-1">
                            Товаров
                        </div>
                        <div class="h5 mb-0 font-weight-bold text-gray-800">
                            @ViewBag.JewelryCount
                        </div>
                    </div>
                    <i class="fas fa-gem fa-2x text-gray-300"></i>
                </div>
            </div>
        </div>
    </div>
</div>

<a asp-controller="Jewelries" asp-action="Create" class="btn btn-warning btn-lg">
    <i class="fas fa-plus me-2"></i>Добавить товар
</a>
