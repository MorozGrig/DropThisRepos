@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Сводка";
}

<div class="d-flex justify-content-between align-items-center mb-4 border-bottom pb-2">
    <h1 class="h3 mb-0 text-warning">💎 Администрирование магазина</h1>
    <a asp-controller="Jewelries" asp-action="Create" class="btn btn-warning">
        <i class="fas fa-plus me-2"></i>Создать товар
    </a>
</div>

<div class="row g-3 mb-4">
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Товаров в каталоге</p>
                <div class="fs-3 fw-bold">@ViewBag.JewelryCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Пользователей</p>
                <div class="fs-3 fw-bold">@ViewBag.UserCount</div>
            </div>
        </div>
    </div>
    <div class="col-md-4">
        <div class="card shadow-sm border-0 h-100">
            <div class="card-body">
                <p class="text-muted mb-1">Заказов</p>
                <div class="fs-3 fw-bold">@ViewBag.OrderCount</div>
            </div>
        </div>
    </div>
</div>

<div class="card shadow-sm border-0">
    <div class="card-header bg-white fw-semibold">Быстрые действия</div>
    <div class="card-body">
        <div class="d-flex flex-wrap gap-2">
            <a asp-controller="Jewelries" asp-action="Index" class="btn btn-outline-primary">Управление товарами</a>
            <a asp-controller="JewelryTips" asp-action="Index" class="btn btn-outline-primary">Управление категориями</a>
            <a asp-controller="Suppliers" asp-action="Index" class="btn btn-outline-primary">Управление брендами</a>
            <a asp-controller="AdminOrders" asp-action="Index" class="btn btn-outline-primary">Обработка заказов</a>
            <a asp-controller="Users" asp-action="Index" class="btn btn-outline-primary">Управление пользователями</a>
        </div>
    </div>
</div>
