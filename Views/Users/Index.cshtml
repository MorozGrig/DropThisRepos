@model IEnumerable<DropThisSite.Models.User>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Пользователи";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Пользователи</h1>
    <a asp-action="Create" class="btn btn-primary">Создать</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Логин</th>
                    <th>Email</th>
                    <th>Телефон</th>
                    <th>Роль</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.Login</td>
                        <td>@item.Email</td>
                        <td>@item.Phone</td>
                        <td>@item.Role?.NameRole</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.IdUser" class="btn btn-sm btn-outline-primary">Редактировать</a>
                            <a asp-action="Delete" asp-route-id="@item.IdUser" class="btn btn-sm btn-outline-danger">Удалить</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
