@model DropThisSite.Models.ViewModels.LoginViewModel

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-5">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h3 class="text-center mb-4">🔐 Вход</h3>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-action="Login" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Login" class="form-label fw-bold">Логин</label>
                            <input asp-for="Login" class="form-control" maxlength="50" />
                            <span asp-validation-for="Login" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold">Пароль</label>
                            <input asp-for="Password" type="password" class="form-control" maxlength="64" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <button class="btn btn-primary w-100 py-3">Войти</button>
                    </form>
                    <div class="text-center mt-4">
                        <a asp-action="Register" class="text-decoration-none">Зарегистрироваться</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
