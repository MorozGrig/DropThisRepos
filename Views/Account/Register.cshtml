@model DropThisSite.Models.ViewModels.RegisterViewModel

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow">
                <div class="card-body p-5">
                    <h3 class="text-center mb-4">👤 Регистрация</h3>

                    @if (ViewBag.Error != null)
                    {
                        <div class="alert alert-danger">@ViewBag.Error</div>
                    }

                    <form asp-action="Register" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4">
                            <label asp-for="Login" class="form-label fw-bold">Логин</label>
                            <input asp-for="Login" class="form-control" maxlength="50" />
                            <span asp-validation-for="Login" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Password" class="form-label fw-bold">Пароль</label>
                            <input asp-for="Password" type="password" class="form-control" maxlength="64" />
                            <span asp-validation-for="Password" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Email" class="form-label fw-bold">Электронная почта</label>
                            <input asp-for="Email" type="email" class="form-control" maxlength="100" placeholder="example@email.com" />
                            <small class="text-muted">Формат: example@email.com</small><br /><span asp-validation-for="Email" class="text-danger"></span>
                        </div>
                        <div class="mb-4">
                            <label asp-for="Phone" class="form-label fw-bold">Телефон</label>
                            <input asp-for="Phone" type="tel" class="form-control" maxlength="20" placeholder="+7 (999) 123-45-67" pattern="^\+?[0-9\-\s\(\)]{7,20}$" title="Используйте формат: +7 (999) 123-45-67" />
                            <small class="text-muted">Формат: +7 (999) 123-45-67</small><br /><span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <button class="btn btn-success w-100 py-3">Зарегистрироваться</button>
                    </form>
                    <div class="text-center mt-4">
                        <a asp-action="Login" class="text-decoration-none">Войти</a>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
