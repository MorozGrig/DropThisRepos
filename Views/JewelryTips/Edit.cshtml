@model DropThisSite.Models.JewelryTip
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Редактирование категории";
}
<h1 class="h3 mb-3">Редактировать категорию</h1>
<div class="card shadow-sm"><div class="card-body">
<form asp-action="Edit" class="row g-3">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="IdJewelryTip" />
    <div class="col-md-6">
        <label asp-for="NameJewelryTip" class="form-label">Название</label>
        <input asp-for="NameJewelryTip" class="form-control" />
        <span asp-validation-for="NameJewelryTip" class="text-danger"></span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
    </div>
</form></div></div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
