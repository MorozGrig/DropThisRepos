@model DropThisSite.Models.JewelryTip

@{
    ViewData["Title"] = "Редактирование";
}

<h1>Редактировать</h1>

<h4>JewelryTip</h4>
<hr />
<div class="row">
    <div class="col-md-4">
        <form asp-action="Edit">
            <div asp-validation-summary="ModelOnly" class="text-danger"></div>
            <input type="hidden" asp-for="IdJewelryTip" />
            <div class="form-group">
                <label asp-for="NameJewelryTip" class="control-label"></label>
                <input asp-for="NameJewelryTip" class="form-control" />
                <span asp-validation-for="NameJewelryTip" class="text-danger"></span>
            </div>
            <div class="form-group">
                <input type="submit" value="Сохранить" class="btn btn-primary" />
            </div>
        </form>
    </div>
</div>

<div>
    <a asp-action="Index">Назад к списку</a>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
