@model IEnumerable<DropThisSite.Models.Supplier>
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Бренды";
}

<div class="d-flex justify-content-between align-items-center mb-3">
    <h1 class="h3 mb-0">Бренды</h1>
    <a asp-action="Create" class="btn btn-primary">Создать</a>
</div>

<div class="card shadow-sm">
    <div class="table-responsive">
        <table class="table table-striped table-hover align-middle mb-0">
            <thead class="table-light">
                <tr>
                    <th>Название</th>
                    <th>Телефон</th>
                    <th>Email</th>
                    <th class="text-end">Действия</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var item in Model)
                {
                    <tr>
                        <td>@item.NameSupplier</td>
                        <td>@item.PhoneSupplier</td>
                        <td>@item.EmailSupplier</td>
                        <td class="text-end">
                            <a asp-action="Edit" asp-route-id="@item.IdSupplier" class="btn btn-sm btn-outline-primary">Редактировать</a>
                            <a asp-action="Delete" asp-route-id="@item.IdSupplier" class="btn btn-sm btn-outline-danger">Удалить</a>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    </div>
</div>
