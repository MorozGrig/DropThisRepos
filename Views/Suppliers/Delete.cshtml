@model DropThisSite.Models.Supplier

@{
    ViewData["Title"] = "Удаление";
}

<h1>Удалить</h1>

<h3>Are you sure you want to delete this?</h3>
<div>
    <h4>Бренд</h4>
    <hr />
    <dl class="row">
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.NameSupplier)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.NameSupplier)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.PhoneSupplier)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.PhoneSupplier)
        </dd>
        <dt class = "col-sm-2">
            @Html.DisplayNameFor(model => model.EmailSupplier)
        </dt>
        <dd class = "col-sm-10">
            @Html.DisplayFor(model => model.EmailSupplier)
        </dd>
    </dl>
    
    <form asp-action="Delete">
        <input type="hidden" asp-for="IdSupplier" />
        <input type="submit" value="Удалить" class="btn btn-danger" /> |
        <a asp-action="Index">Назад к списку</a>
    </form>
</div>
