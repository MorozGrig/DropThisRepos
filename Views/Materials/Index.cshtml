@model IEnumerable<DropThisSite.Models.Material>

@{
    ViewData["Title"] = "Список";
}

<h1>Список</h1>

<p>
    <a asp-action="Create">Создать запись</a>
</p>
<table class="table">
    <thead>
        <tr>
            <th>
                @Html.DisplayNameFor(model => model.NameMaterial)
            </th>
            <th>
                @Html.DisplayNameFor(model => model.Proba)
            </th>
            <th></th>
        </tr>
    </thead>
    <tbody>
@foreach (var item in Model) {
        <tr>
            <td>
                @Html.DisplayFor(modelItem => item.NameMaterial)
            </td>
            <td>
                @Html.DisplayFor(modelItem => item.Proba)
            </td>
            <td>
                <a asp-action="Edit" asp-route-id="@item.IdMaterial">Редактировать</a> |
                <a asp-action="Details" asp-route-id="@item.IdMaterial">Подробнее</a> |
                <a asp-action="Delete" asp-route-id="@item.IdMaterial">Удалить</a>
            </td>
        </tr>
}
    </tbody>
</table>
