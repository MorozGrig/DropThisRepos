@model DropThisSite.Models.Jewelry

@{
    ViewData["Title"] = "Карточка товара";
    var imagePath = string.IsNullOrWhiteSpace(Model.ImagePath)
        ? "/images/placeholder-product.svg"
        : Model.ImagePath;
}

<div class="container my-5">
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <img src="@imagePath"
                     class="card-img-top details-product-image"
                     alt="@Model.NameJewelry">
            </div>
        </div>
        <div class="col-lg-6">
            <h1 class="mb-3">@Model.NameJewelry</h1>
            <p class="text-muted mb-2">Категория: <strong>@Model.JewelryTip?.NameJewelryTip</strong></p>
            <p class="text-muted mb-2">Бренд: <strong>@Model.Supplier?.NameSupplier</strong></p>
            <p class="text-muted mb-2">Материал: <strong>@Model.Material?.NameMaterial</strong></p>
            <p class="text-muted mb-2">Вставка: <strong>@(Model.Stone?.NameStone ?? "Без вставки")</strong></p>
            <h3 class="text-danger my-4">@Model.PriceJewelry.ToString("N0") ₽</h3>

            <div class="card bg-light border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title">Описание</h5>
                    <p class="mb-0">
                        Элегантное украшение для повседневного образа и особых случаев.
                        Выполнено из качественных материалов и создано для того, чтобы подчеркнуть ваш стиль.
                    </p>
                </div>
            </div>



            @if (User.IsInRole("Админ"))
            {
                <div class="mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.IdJewelry" class="btn btn-outline-primary btn-sm">Редактировать товар</a>
                </div>
            }
        </div>
    </div>
</div>

<style>
    .details-product-image {
        width: 100%;
        max-height: 520px;
        object-fit: cover;
        object-position: center;
    }
</style>

<script>
    async function addToCart(button) {
        const id = button.dataset.id;
        const originalText = button.innerHTML;

        button.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Добавляем...';
        button.disabled = true;

        try {
            const formData = new FormData();
            formData.append('id', id);

            const response = await fetch('/Home/AddToCart', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            });

            if (!response.ok) {
                throw new Error('Не удалось добавить товар');
            }

            const data = await response.json();
            const badge = document.getElementById('cartCount');
            if (badge) {
                badge.textContent = data.count;
                badge.style.display = data.count > 0 ? 'block' : 'none';
            }

            button.innerHTML = '<i class="fas fa-check me-2"></i>Добавлено!';
        } catch (error) {
            button.innerHTML = '<i class="fas fa-exclamation me-2"></i>Ошибка';
            console.error(error);
        }

        setTimeout(() => {
            button.innerHTML = originalText;
            button.disabled = false;
        }, 1200);
    }

    document.getElementById('addToCartBtn')?.addEventListener('click', function () {
        addToCart(this);
    });
</script>
