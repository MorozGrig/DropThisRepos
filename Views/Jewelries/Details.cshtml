@model DropThisSite.Models.Jewelry

@{
    ViewData["Title"] = "Карточка товара";
}

<div class="container my-5">
    <div class="row g-4">
        <div class="col-lg-6">
            <div class="card shadow-sm border-0">
                <img src="/images/ring1.jpg" class="card-img-top" alt="@Model.NameJewelry">
            </div>
        </div>
        <div class="col-lg-6">
            <h1 class="mb-3">@Model.NameJewelry</h1>
            <p class="text-muted mb-2">Категория: <strong>@Model.JewelryTip?.NameJewelryTip</strong></p>
            <p class="text-muted mb-2">Бренд: <strong>@Model.Supplier?.NameSupplier</strong></p>
            <p class="text-muted mb-2">Материал: <strong>@Model.Material?.NameMaterial</strong></p>
            <p class="text-muted mb-2">Вставка: <strong>@(Model.Stone?.NameStone ?? "Без вставки")</strong></p>
            <h3 class="text-danger my-4">@Model.PriceJewelry.ToString("N0") ₽</h3>

            <div class="card bg-light border-0 mb-4">
                <div class="card-body">
                    <h5 class="card-title">Описание</h5>
                    <p class="mb-0">
                        Элегантное украшение для повседневного образа и особых случаев.
                        Выполнено из качественных материалов и создано для того, чтобы подчеркнуть ваш стиль.
                    </p>
                </div>
            </div>

            <form asp-controller="Home" asp-action="AddToCart" method="post" class="d-grid gap-2 d-md-flex">
                <input type="hidden" name="id" value="@Model.IdJewelry" />
                <button type="submit" class="btn btn-success btn-lg px-4">
                    <i class="fas fa-shopping-cart me-2"></i>Добавить в корзину
                </button>
                <a asp-action="Index" class="btn btn-outline-secondary btn-lg px-4">Назад в каталог</a>
            </form>

            @if (User.IsInRole("Админ"))
            {
                <div class="mt-3">
                    <a asp-action="Edit" asp-route-id="@Model.IdJewelry" class="btn btn-outline-primary btn-sm">Редактировать товар</a>
                </div>
            }
        </div>
    </div>
</div>
