@model List<DropThisSite.Models.Jewelry>

<div class="container my-5">
    <h1 class="display-4 fw-bold mb-5 text-center">💎 Каталог ювелирных изделий</h1>

    <form method="get" asp-action="Index" class="row mb-4 g-3">
        <div class="col-md-2">
            <select name="categoryId" class="form-select" onchange="this.form.submit()">
                <option value="0">Все категории</option>
                @foreach (var tip in ViewBag.JewelryTips as List<DropThisSite.Models.JewelryTip>)
                {
                    if (tip.IdJewelryTip == (int)ViewBag.SelectedCategoryId)
                    {
                        <option value="@tip.IdJewelryTip" selected="selected">@tip.NameJewelryTip</option>
                    }
                    else
                    {
                        <option value="@tip.IdJewelryTip">@tip.NameJewelryTip</option>
                    }
                }
            </select>
        </div>

        <div class="col-md-2">
            <select name="materialId" class="form-select" onchange="this.form.submit()">
                <option value="0">Все материалы</option>
                @foreach (var material in ViewBag.Materials as List<DropThisSite.Models.Material>)
                {
                    if (material.IdMaterial == (int)ViewBag.SelectedMaterialId)
                    {
                        <option value="@material.IdMaterial" selected="selected">@material.NameMaterial</option>
                    }
                    else
                    {
                        <option value="@material.IdMaterial">@material.NameMaterial</option>
                    }
                }
            </select>
        </div>


        <div class="col-md-2">
            <select name="brandId" class="form-select" onchange="this.form.submit()">
                <option value="0">Все бренды</option>
                @foreach (var supplier in ViewBag.Suppliers as List<DropThisSite.Models.Supplier>)
                {
                    if (supplier.IdSupplier == (int)ViewBag.SelectedBrandId)
                    {
                        <option value="@supplier.IdSupplier" selected="selected">@supplier.NameSupplier</option>
                    }
                    else
                    {
                        <option value="@supplier.IdSupplier">@supplier.NameSupplier</option>
                    }
                }
            </select>
        </div>
        <div class="col-md-2">
            <select name="priceRange" class="form-select" onchange="this.form.submit()">
                @if (string.IsNullOrEmpty((string)ViewBag.SelectedPriceRange))
                {
                    <option value="" selected="selected">Все цены</option>
                }
                else
                {
                    <option value="">Все цены</option>
                }

                @if ("0-10000" == (string)ViewBag.SelectedPriceRange)
                {
                    <option value="0-10000" selected="selected">До 10 000 ₽</option>
                }
                else
                {
                    <option value="0-10000">До 10 000 ₽</option>
                }

                @if ("10000-50000" == (string)ViewBag.SelectedPriceRange)
                {
                    <option value="10000-50000" selected="selected">10 000 - 50 000 ₽</option>
                }
                else
                {
                    <option value="10000-50000">10 000 - 50 000 ₽</option>
                }

                @if ("50000+" == (string)ViewBag.SelectedPriceRange)
                {
                    <option value="50000+" selected="selected">50 000+ ₽</option>
                }
                else
                {
                    <option value="50000+">50 000+ ₽</option>
                }
            </select>
        </div>

        <div class="col-md-2">
            <select name="sort" class="form-select" onchange="this.form.submit()">
                @if (string.IsNullOrEmpty((string)ViewBag.SelectedSort))
                {
                    <option value="" selected="selected">Без сортировки</option>
                }
                else
                {
                    <option value="">Без сортировки</option>
                }

                @if ("price_asc" == (string)ViewBag.SelectedSort)
                {
                    <option value="price_asc" selected="selected">Цена ↑</option>
                }
                else
                {
                    <option value="price_asc">Цена ↑</option>
                }

                @if ("price_desc" == (string)ViewBag.SelectedSort)
                {
                    <option value="price_desc" selected="selected">Цена ↓</option>
                }
                else
                {
                    <option value="price_desc">Цена ↓</option>
                }
            </select>
        </div>


        <div class="col-md-2">
            <input type="number" name="minPrice" class="form-control" min="0" max="10000000" value="@ViewBag.SelectedMinPrice" placeholder="Мин. цена" />
        </div>

        <div class="col-md-2">
            <input type="number" name="maxPrice" class="form-control" min="0" max="10000000" value="@ViewBag.SelectedMaxPrice" placeholder="Макс. цена" />
        </div>
        <div class="col-md-2">
            <div class="input-group">
                <input type="text"
                       class="form-control"
                       name="search"
                       value="@ViewBag.SelectedSearch"
                       maxlength="50"
                       placeholder="Поиск по названию..." />
                <button class="btn btn-outline-warning" type="submit">
                    <i class="fas fa-search"></i>
                </button>
            </div>
        </div>

        <input type="hidden" name="page" value="1" />
    </form>

    <div class="row g-4" id="catalogItems">
        @foreach (var item in Model)
        {
            <div class="col-xl-3 col-lg-4 col-md-6 item-card">
                <div class="card h-100 shadow-lg hover-shadow">
                    <div class="card-body text-center p-4">
                        <i class="fas fa-gem fa-4x text-warning mb-4"></i>
                        <h5 class="card-title fw-bold">@item.NameJewelry</h5>

                        <div class="mb-3">
                            <small class="text-muted d-block">
                                <i class="fas fa-tag me-1"></i>@item.JewelryTip?.NameJewelryTip
                            </small>
                            <small class="text-muted">
                                <i class="fas fa-crown me-1"></i>@item.Material?.NameMaterial
                                @if (item.Stone != null)
                                {
                                    <span class="ms-2">
                                        <i class="fas fa-gem me-1 text-danger"></i>@item.Stone.NameStone
                                    </span>
                                }
                            </small>
                        </div>

                        <div class="h3 text-danger fw-bold mb-4">@item.PriceJewelry.ToString("N0") ₽</div>

                        <div class="d-grid gap-2">
                            <button class="btn btn-primary btn-lg add-to-cart" data-id="@item.IdJewelry" type="button">
                                <i class="fas fa-cart-plus me-2"></i>В корзину
                            </button>
                            <a asp-action="Details" asp-route-id="@item.IdJewelry"
                               class="btn btn-outline-secondary">
                                <i class="fas fa-eye me-2"></i>Подробнее
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        }
    </div>

    @if (ViewBag.TotalPages > 1)
    {
        <nav class="mt-5">
            <ul class="pagination justify-content-center">
                @for (int i = 1; i <= (int)ViewBag.TotalPages; i++)
                {
                    <li class="page-item @(i == ViewBag.CurrentPage ? "active" : "")">
                        <a class="page-link"
                           asp-action="Index"
                           asp-route-page="@i"
                           asp-route-categoryId="@ViewBag.SelectedCategoryId"
                           asp-route-materialId="@ViewBag.SelectedMaterialId"
                           asp-route-brandId="@ViewBag.SelectedBrandId"
                           asp-route-minPrice="@ViewBag.SelectedMinPrice"
                           asp-route-maxPrice="@ViewBag.SelectedMaxPrice"
                           asp-route-priceRange="@ViewBag.SelectedPriceRange"
                           asp-route-search="@ViewBag.SelectedSearch"
                           asp-route-sort="@ViewBag.SelectedSort">@i</a>
                    </li>
                }
            </ul>
        </nav>
    }
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 20px 40px rgba(0,0,0,0.2) !important;
        transition: all 0.3s ease;
    }
</style>

<script>
    let cartCount = 0;

    async function addToCart(id, button) {
        const originalText = button.innerHTML;

        button.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Добавляем...';
        button.disabled = true;

        try {
            const formData = new FormData();
            formData.append('id', id);

            const response = await fetch('/Home/AddToCart', {
                method: 'POST',
                headers: { 'X-Requested-With': 'XMLHttpRequest' },
                body: formData
            });

            const data = await response.json();
            cartCount = data.count;

            button.innerHTML = '<i class="fas fa-check-circle text-success me-2"></i>В корзине! (' + cartCount + ')';
            button.classList.add('btn-success');

            updateCartBadge();

        } catch (e) {
            button.innerHTML = originalText;
            alert('Ошибка добавления в корзину');
        }

        setTimeout(() => {
            button.innerHTML = originalText;
            button.classList.remove('btn-success');
            button.disabled = false;
        }, 2000);
    }

    function updateCartBadge() {
        const badge = document.getElementById('cartCount');
        if (badge) {
            badge.textContent = cartCount;
            badge.style.display = cartCount > 0 ? 'inline' : 'none';
        }
    }

    document.querySelectorAll('.add-to-cart').forEach(button => {
        button.addEventListener('click', () => addToCart(button.dataset.id, button));
    });
</script>
