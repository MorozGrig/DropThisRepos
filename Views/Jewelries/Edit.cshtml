@model DropThisSite.Models.Jewelry
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Редактирование украшения";
}

<h1 class="h3 mb-3">Редактировать украшение</h1>
<div class="card shadow-sm"><div class="card-body">
<form asp-action="Edit" class="row g-3" enctype="multipart/form-data">
    <div asp-validation-summary="ModelOnly" class="text-danger"></div>
    <input type="hidden" asp-for="IdJewelry" />
    <div class="col-md-6">
        <label asp-for="NameJewelry" class="form-label">Название украшения</label>
        <input asp-for="NameJewelry" class="form-control" />
        <span asp-validation-for="NameJewelry" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="IdJewelryTip" class="form-label">Тип украшения</label>
        <select asp-for="IdJewelryTip" class="form-select" asp-items="ViewBag.IdJewelryTip"></select>
        <span asp-validation-for="IdJewelryTip" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="IdMaterial" class="form-label">Материал</label>
        <select asp-for="IdMaterial" class="form-select" asp-items="ViewBag.IdMaterial"></select>
        <span asp-validation-for="IdMaterial" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="IdStone" class="form-label">Камень</label>
        <select asp-for="IdStone" class="form-select" asp-items="ViewBag.IdStone"></select>
        <span asp-validation-for="IdStone" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="IdSupplier" class="form-label">Бренд</label>
        <select asp-for="IdSupplier" class="form-select" asp-items="ViewBag.IdSupplier"></select>
        <span asp-validation-for="IdSupplier" class="text-danger"></span>
    </div>
    <div class="col-md-6">
        <label asp-for="PriceJewelry" class="form-label">Стоимость украшения</label>
        <input asp-for="PriceJewelry" class="form-control" data-val-number="Введите цену товара" data-val-required="Введите цену товара" />
        <span asp-validation-for="PriceJewelry" class="text-danger"></span>
    </div>
    <div class="col-12">
        <label class="form-label d-block">Текущее изображение</label>
        <img src="@(string.IsNullOrWhiteSpace(Model.ImagePath) ? "/images/placeholder-product.svg" : Model.ImagePath)"
             alt="@Model.NameJewelry"
             style="width: 180px; height: 180px; object-fit: cover; border-radius: 8px;" />
    </div>
    <div class="col-12">
        <label for="imageFile" class="form-label">Заменить изображение</label>
        <input type="file" id="imageFile" name="imageFile" class="form-control" accept=".jpg,.jpeg,.png,image/jpeg,image/png" />
        <div class="form-text">Разрешены только JPG/JPEG/PNG, размер до 5 МБ.</div>
        <span class="text-danger">@Html.ValidationMessage("imageFile")</span>
    </div>
    <div class="col-12 d-flex gap-2">
        <button type="submit" class="btn btn-primary">Сохранить</button>
        <a asp-action="Index" class="btn btn-outline-secondary">Отмена</a>
    </div>
</form></div></div>
@section Scripts { @{await Html.RenderPartialAsync("_ValidationScriptsPartial");} }
