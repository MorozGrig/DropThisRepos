@model List<DropThisSite.Models.Jewelry>
@{
    ViewData["Title"] = "Главная";
}

<div>
    <div class="container">
        <h1 class="hero-section h1 text-center">Эксклюзивные украшения</h1>
        <p class="text-center">Золото, серебро, платина. Индивидуальный подход</p>
    </div>
</div>

<div class="container my-5">
    <h2 class="mb-4 text-center">Новинки каталога</h2>

    @if (!Model.Any())
    {
        <div class="alert alert-warning text-center">Новинки пока не добавлены.</div>
    }
    else
    {
        <div class="row">
            @foreach (var item in Model)
            {
                var imagePath = string.IsNullOrWhiteSpace(item.ImagePath)
                ? "/images/placeholder-product.svg"
                : item.ImagePath;

                <div class="col-md-4 mb-4">
                    <div class="card h-100 shadow-sm border-warning">
                        <img src="@imagePath" class="card-img-top" alt="@item.NameJewelry">
                        <div class="card-body">
                            <h5 class="card-title">@item.NameJewelry</h5>
                            <p class="card-text text-muted">@item.Material?.NameMaterial • @item.JewelryTip?.NameJewelryTip</p>
                            <h4 class="text-danger">@item.PriceJewelry.ToString("N0") ₽</h4>
                            <a asp-controller="Jewelries" asp-action="Details" asp-route-id="@item.IdJewelry"
                               class="btn btn-primary w-100 mb-2">
                                Подробнее
                            </a>
                            <button type="button"
                                    data-id="@item.IdJewelry"
                                    class="btn btn-success w-100 add-to-cart-btn"
                                    onclick="addToCart(this)">
                                <i class="fas fa-shopping-cart"></i> В корзину
                            </button>
                        </div>
                    </div>
                </div>
            }
        </div>
    }
</div>

<script>
async function addToCart(button) {
    const id = button.dataset.id;
    const originalText = button.innerHTML;

    button.innerHTML = '<i class="fas fa-spinner fa-spin me-2"></i>Добавляем...';
    button.disabled = true;

    try {
        const formData = new FormData();
        formData.append('id', id);

        const response = await fetch('/Home/AddToCart', {
            method: 'POST',
            headers: { 'X-Requested-With': 'XMLHttpRequest' },
            body: formData
        });

        if (!response.ok) {
            throw new Error('Не удалось добавить товар');
        }

        const data = await response.json();

        const badges = document.querySelectorAll('#cartCount');
        badges.forEach(badge => {
            badge.textContent = data.count;
            badge.style.display = data.count > 0 ? 'block' : 'none';
        });

        button.innerHTML = '<i class="fas fa-check me-2"></i>Добавлено!';
    } catch (error) {
        console.error('Ошибка:', error);
        button.innerHTML = '<i class="fas fa-exclamation me-2"></i>Ошибка';
    }

    setTimeout(() => {
        button.innerHTML = originalText;
        button.disabled = false;
    }, 1500);
}
</script>

<style>
.add-to-cart-btn {
    transition: all 0.3s ease;
}

.add-to-cart-btn:hover {
    transform: translateY(-2px);
    box-shadow: 0 5px 15px rgba(0,0,0,0.2);
}
</style>
