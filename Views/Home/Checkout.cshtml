@model dynamic
<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0"><i class="fas fa-credit-card me-2"></i>Оформление заказа</h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="CheckoutProcess" method="post">
                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">Имя</label>
                                <input name="name" class="form-control" required />
                            </div>
                            <div class="col-md-6 mb-4">
                                <label class="form-label fw-bold">Телефон</label>
                                <input name="phone" type="tel" class="form-control" required />
                            </div>
                            <div class="col-12 mb-4">
                                <label class="form-label fw-bold">Email</label>
                                <input name="email" type="email" class="form-control" required />
                            </div>
                            <div class="col-12 mb-4">
                                <label class="form-label fw-bold">Адрес доставки</label>
                                <textarea name="address" class="form-control" rows="3" required></textarea>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4>Итого: <span id="totalPrice">@ViewBag.TotalPrice ₽</span></h4>
                            <button type="submit" class="btn btn-success btn-lg px-5">
                                <i class="fas fa-check me-2"></i>Оформить заказ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
