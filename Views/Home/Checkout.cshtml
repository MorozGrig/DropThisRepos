@model DropThisSite.Models.ViewModels.CheckoutViewModel

<div class="container my-5">
    <div class="row justify-content-center">
        <div class="col-lg-8">
            <div class="card shadow-lg">
                <div class="card-header bg-warning text-dark">
                    <h3 class="mb-0"><i class="fas fa-credit-card me-2"></i>Оформление заказа</h3>
                </div>
                <div class="card-body p-5">
                    <form asp-action="CheckoutProcess" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="row">
                            <div class="col-md-6 mb-4">
                                <label asp-for="Name" class="form-label fw-bold">Имя</label>
                                <input asp-for="Name" class="form-control" maxlength="100" />
                                <span asp-validation-for="Name" class="text-danger"></span>
                            </div>
                            <div class="col-md-6 mb-4">
                                <label asp-for="Phone" class="form-label fw-bold">Телефон</label>
                                <input asp-for="Phone" type="tel" class="form-control" maxlength="20" placeholder="+7 (999) 123-45-67" pattern="^\+?[0-9\-\s\(\)]{7,20}$" title="Используйте формат: +7 (999) 123-45-67" />
                                <small class="text-muted">Формат: +7 (999) 123-45-67</small><br /><span asp-validation-for="Phone" class="text-danger"></span>
                            </div>
                            <div class="col-12 mb-4">
                                <label asp-for="Email" class="form-label fw-bold">Электронная почта</label>
                                <input asp-for="Email" type="email" class="form-control" maxlength="100" placeholder="example@email.com" />
                                <small class="text-muted">Формат: example@email.com</small><br /><span asp-validation-for="Email" class="text-danger"></span>
                            </div>
                            <div class="col-12 mb-4">
                                <label asp-for="Address" class="form-label fw-bold">Адрес доставки</label>
                                <textarea asp-for="Address" class="form-control" rows="3" maxlength="250"></textarea>
                                <span asp-validation-for="Address" class="text-danger"></span>
                            </div>
                        </div>

                        <hr class="my-4">

                        <div class="d-flex justify-content-between align-items-center mb-4">
                            <h4>Итого: <span id="totalPrice">@ViewBag.TotalPrice ₽</span></h4>
                            <button type="submit" class="btn btn-success btn-lg px-5">
                                <i class="fas fa-check me-2"></i>Оформить заказ
                            </button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
