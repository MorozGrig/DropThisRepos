@model DropThisSite.Models.ViewModels.CheckoutViewModel
@{
    ViewData["Title"] = "Оформление заказа";
    var yandexApiKey = ViewBag.YandexApiKey as string ?? string.Empty;
}

<div class="container mt-5">
    <h2 class="mb-4">Оформление заказа</h2>

    @if (string.IsNullOrWhiteSpace(yandexApiKey))
    {
        <div class="alert alert-warning">
            Yandex Maps API key не настроен. Карта и подсказки адреса недоступны.
        </div>
    }

    <div class="row">
        <div class="col-md-7">
            <form asp-action="CheckoutProcess" method="post">
                <div asp-validation-summary="All" class="text-danger"></div>

                <div class="mb-3">
                    <label asp-for="Name" class="form-label fw-bold">Имя</label>
                    <input asp-for="Name" class="form-control" />
                    <span asp-validation-for="Name" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Phone" class="form-label fw-bold">Телефон</label>
                    <input asp-for="Phone" class="form-control" placeholder="+7XXXXXXXXXX" />
                    <span asp-validation-for="Phone" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Email" class="form-label fw-bold">Email</label>
                    <input asp-for="Email" class="form-control" />
                    <span asp-validation-for="Email" class="text-danger"></span>
                </div>

                <div class="mb-3">
                    <label asp-for="Address" class="form-label fw-bold">Адрес доставки</label>
                    <input asp-for="Address" id="selectedAddress" class="form-control" autocomplete="off" />
                    <div class="form-text">Введите адрес вручную, выберите из подсказки или кликните на карту.</div>
                    <span asp-validation-for="Address" class="text-danger"></span>
                </div>

                <input asp-for="AddressCoordinates" id="addressCoordinates" type="hidden" />
                <input asp-for="IsAddressVerified" id="isAddressVerified" type="hidden" />

                <div class="mb-3">
                    <div id="map" style="height: 350px; border-radius: 8px;"></div>
                </div>

                <button type="submit" class="btn btn-success btn-lg">Подтвердить заказ</button>
            </form>
        </div>

        <div class="col-md-5">
            <div class="card shadow-sm">
                <div class="card-body">
                    <h5 class="card-title">Ваш заказ</h5>
                    <p><strong>Товаров:</strong> @((ViewBag.CartIds as List<int>)?.Count ?? 0) шт.</p>
                    <p><strong>Общая сумма:</strong> <span class="text-danger fs-4">@ViewBag.TotalPrice ₽</span></p>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{ await Html.RenderPartialAsync("_ValidationScriptsPartial"); }

    @if (!string.IsNullOrWhiteSpace(yandexApiKey))
    {
        <script src="https://api-maps.yandex.ru/2.1/?apikey=@yandexApiKey&lang=ru_RU"></script>
        <script>
            (function () {
                const addressInput = document.getElementById('selectedAddress');
                const coordsInput = document.getElementById('addressCoordinates');
                const verifiedInput = document.getElementById('isAddressVerified');

                const clearVerification = () => {
                    verifiedInput.value = 'false';
                };

                addressInput.addEventListener('input', clearVerification);

                ymaps.ready(function () {
                    const map = new ymaps.Map('map', {
                        center: [55.751244, 37.618423],
                        zoom: 10,
                        controls: ['zoomControl', 'geolocationControl']
                    });

                    let placemark;

                    const suggestView = new ymaps.SuggestView('selectedAddress');
                    suggestView.events.add('select', function (event) {
                        const selectedAddress = event.get('item').value;
                        addressInput.value = selectedAddress;

                        ymaps.geocode(selectedAddress, { results: 1 }).then(function (res) {
                            const geoObject = res.geoObjects.get(0);
                            if (!geoObject) {
                                clearVerification();
                                return;
                            }

                            const coords = geoObject.geometry.getCoordinates();
                            coordsInput.value = `${coords[0]},${coords[1]}`;
                            verifiedInput.value = 'true';

                            if (!placemark) {
                                placemark = new ymaps.Placemark(coords);
                                map.geoObjects.add(placemark);
                            } else {
                                placemark.geometry.setCoordinates(coords);
                            }

                            map.setCenter(coords, 16);
                        });
                    });

                    map.events.add('click', function (e) {
                        const coords = e.get('coords');
                        ymaps.geocode(coords).then(function (res) {
                            const geoObject = res.geoObjects.get(0);
                            if (!geoObject) {
                                clearVerification();
                                return;
                            }

                            const address = geoObject.getAddressLine();
                            addressInput.value = address;
                            coordsInput.value = `${coords[0]},${coords[1]}`;
                            verifiedInput.value = 'true';

                            if (!placemark) {
                                placemark = new ymaps.Placemark(coords);
                                map.geoObjects.add(placemark);
                            } else {
                                placemark.geometry.setCoordinates(coords);
                            }
                        });
                    });

                    if (addressInput.value) {
                        ymaps.geocode(addressInput.value, { results: 1 }).then(function (res) {
                            const geoObject = res.geoObjects.get(0);
                            if (!geoObject) {
                                return;
                            }

                            const coords = geoObject.geometry.getCoordinates();
                            coordsInput.value = `${coords[0]},${coords[1]}`;

                            placemark = new ymaps.Placemark(coords);
                            map.geoObjects.add(placemark);
                            map.setCenter(coords, 14);
                        });
                    }
                });
            })();
        </script>
    }
}
